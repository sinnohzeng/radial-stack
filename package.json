{
  "name": "radial-stack",
  "version": "1.0.0",
  "description": "基于 SVG 多层径向渐变叠加技术的文本标识图生成器，参照 OpenAI 渐变风格",
  "type": "module",
  "main": "generate.js",
  "bin": {
    "radial-stack": "./generate.js"
  },
